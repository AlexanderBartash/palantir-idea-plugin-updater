<!-- https://plugins.jetbrains.com/docs/intellij/dynamic-plugins.html -->
<idea-plugin url="https://github.com/palantir/palantir-idea-plugin-updater" require-restart="false">
    <id>palantir-addon-updater</id>
    <name>Palantir Addon Updater</name>

    <vendor email="jetbrains-plugins@palantir.com" url="https://github.com/palantir/palantir-idea-plugin-updater">
        Palantir
    </vendor>

    <description>
        <![CDATA[
    <h2>Palantir Addon Updater</h2>

    <p>
    Runs in the background and attempts to upgrade
    <a href="https://plugins.jetbrains.com/vendor/05482c17-76bf-4895-ab20-d5237ceb53a7">Palantir IntelliJ plugins</a>
    every hour.
    After a successful plugin update, a popup is shown to suggest an IDE restart.
    </p>
    ]]>
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.palantir.gradle.ideapluginupdater.PluginUpdateProjectActivity"/>

        <applicationService serviceImplementation="com.palantir.gradle.ideapluginupdater.PalantirI18nBundle"/>
        <projectService serviceImplementation="com.palantir.gradle.ideapluginupdater.PluginUpdateService"/>

        <notificationGroup id="notifications.group.palantir.plugins.updates"
                           bundle="i18n.PalantirBundle"
                           displayType="BALLOON"
                           key="notifications.group.palantir.plugins.updates"/>
    </extensions>
</idea-plugin>
